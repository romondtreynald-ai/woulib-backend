# Woulib Plus — environment variables
# Copy this to .env and fill in your real values

# Server
PORT=3000
NODE_ENV=development
APP_URL=https://your-app-url.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/woulib_plus

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# MonCash (Digicel Haiti)
# Get credentials at: https://sandbox.moncashbutton.digicelgroup.com
MONCASH_CLIENT_ID=your_moncash_client_id
MONCASH_CLIENT_SECRET=your_moncash_client_secret
MONCASH_BASE_URL=https://sandbox.moncashbutton.digicelgroup.com/Moncash-middleware
# For production: https://moncashbutton.digicelgroup.com/Moncash-middleware

# NatCash (Natcom Haiti)
# Contact Natcom business team to get credentials
NATCASH_MERCHANT_ID=your_natcash_merchant_id
NATCASH_API_KEY=your_natcash_api_key
NATCASH_BASE_URL=https://api.natcash.ht
